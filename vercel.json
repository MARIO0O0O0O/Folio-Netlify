{
  "rewrites": [
    { "source": "/login", "destination": "/pages/auth.html" },
    { "source": "/signup", "destination": "/pages/auth.html" },
    { "source": "/register", "destination": "/pages/auth.html" },
    { "source": "/donate", "destination": "/pages/support.html" },
    { "source": "/invest", "destination": "/pages/support.html" },
    { "source": "/app/(.*)", "destination": "/pages/dashboard.html" },
    { "source": "/@(?<username>.*)", "destination": "/pages/profile.html?u=:username" }
  ]
}
